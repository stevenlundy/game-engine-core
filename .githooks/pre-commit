#!/usr/bin/env bash
# .githooks/pre-commit
#
# Runs fast local checks before every commit:
#   1. gofmt   — fail if any staged .go files are not formatted
#   2. go vet  — fail on suspicious constructs
#   3. golangci-lint — fail on lint errors (if installed)
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Or add to your shell profile to apply to all repos:
#   git config --global core.hooksPath ~/.githooks

set -euo pipefail

# ── 1. gofmt ────────────────────────────────────────────────────────────────
echo "pre-commit: running gofmt..."
UNFORMATTED=$(gofmt -l $(git diff --cached --name-only --diff-filter=ACM | grep '\.go$') 2>/dev/null || true)
if [[ -n "$UNFORMATTED" ]]; then
  echo "❌ gofmt: the following files need formatting (run 'gofmt -w <file>'):"
  echo "$UNFORMATTED" | sed 's/^/  /'
  exit 1
fi

# ── 2. go vet ───────────────────────────────────────────────────────────────
echo "pre-commit: running go vet..."
go vet ./... 2>&1 || { echo "❌ go vet failed"; exit 1; }

# ── 3. golangci-lint (optional — skip if not installed) ─────────────────────
if command -v golangci-lint &>/dev/null; then
  echo "pre-commit: running golangci-lint..."
  golangci-lint run ./... 2>&1 || { echo "❌ golangci-lint failed"; exit 1; }
else
  echo "pre-commit: golangci-lint not found, skipping (install with: brew install golangci-lint)"
fi

echo "✅ pre-commit checks passed"
